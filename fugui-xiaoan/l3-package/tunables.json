{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "tunables and conflictRules",
  "description": "Fugui Xiaoan N10 tunable parameters + cross_param conflict detection rules. Based on v4.7.",
  "generalParameters": [
    { "name": "confidence_threshold", "defaultValue": 0.4, "valueRange": [0.0, 1.0], "purpose": "Threshold for 'pretend to know' detection", "consumer": "DET recheck" },
    { "name": "turnHistory_limit", "defaultValue": 20, "valueRange": [5, 100], "purpose": "Base turn retention count for roomConversationLog", "consumer": "session-store" },
    { "name": "critical_room_history_boost", "defaultValue": 2.0, "valueRange": [1.0, 5.0], "purpose": "Multiplier for critical room turn retention", "consumer": "session-store", "version": "v4.7" },
    { "name": "pending_fields_ttl", "defaultValue": "24h", "valueRange": ["1h", "168h"], "purpose": "Half-finished record retention duration", "consumer": "session-store" },
    { "name": "boundary_coverage_threshold", "defaultValue": 0.85, "valueRange": [0.50, 1.00], "purpose": "Boundary coverage completeness threshold", "consumer": "design-phase validation" },
    { "name": "contract_inheritance_limit", "defaultValue": 0.3, "valueRange": [0.1, 0.5], "purpose": "Cross-node contract inheritance injection cap", "consumer": "dispatcher" },
    { "name": "cold_start_observation_window", "defaultValue": 50, "valueRange": [20, 200], "purpose": "Cold start observation window session count", "consumer": "cold start monitor" },
    { "name": "cold_start_emergency_threshold", "defaultValue": 0.5, "valueRange": [0.3, 0.8], "purpose": "Emergency thaw trigger threshold", "consumer": "cold start monitor" },
    { "name": "pid_kp", "defaultValue": 0.1, "valueRange": [0.01, 1.0], "purpose": "P feedback control coefficient", "consumer": "auto-tuning engine" },
    { "name": "strengthens_weight_cap", "defaultValue": 3, "valueRange": [1, 10], "purpose": "Cap for strengthens edge weight accumulation", "consumer": "context-manager", "version": "v4.7" },
    { "name": "changelevel_major_sample_rate", "defaultValue": 0.05, "valueRange": [0.01, 0.20], "purpose": "Sampling rate for changeLevel major audit", "consumer": "audit engine", "version": "v4.7" },
    { "name": "max_critical_rooms", "defaultValue": 3, "valueRange": [1, 10], "purpose": "Max concurrent critical rooms for cross_param budget check", "consumer": "context-manager", "version": "v4.7" }
  ],
  "fieldBasedParameters": [
    { "name": "amount_limit_max", "defaultValue": 999999, "valueRange": [0, 999999999], "purpose": "Max amount for value check", "consumer": "DET recheck" },
    { "name": "session_checkpoint_ttl", "defaultValue": 604800, "valueRange": [86400, 2592000], "purpose": "Session checkpoint expiry in seconds (default 7 days)", "consumer": "dispatcher", "version": "v4.7" }
  ],
  "conflictRules": {
    "defaultViolationAction": {
      "single_param": "hard_reject",
      "cross_param": "warning"
    },
    "single_param": [
      {
        "name": "confidence_threshold_range_check",
        "check": "0 <= confidence_threshold <= 1"
      }
    ],
    "cross_param": [
      {
        "name": "critical_room_context_budget_check",
        "violation_action": "warning",
        "params": ["turnHistory_limit", "critical_room_history_boost", "max_critical_rooms"],
        "compute": "max_critical_rooms * turnHistory_limit * critical_room_history_boost * 200 > 128000 * 0.6"
      }
    ]
  }
}
