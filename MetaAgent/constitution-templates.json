{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "宪法模板索引",
  "description": "N9 根据 N3 中每个 intent 的 taskType 选择对应模板。field_based 用元智能体简化版，topic_based 用态控架构基准版。",
  "templates": [
    {
      "templateId": "metaagent-field-based",
      "taskType": "field_based",
      "path": "templates/field_based/template.md",
      "tags": {
        "required": [
          "@section constitution",
          "@section role",
          "@section convergence",
          "@section ask-rules",
          "@section output-schema",
          "@section completion",
          "@section validation",
          "@section modification",
          "@section off-task-detection",
          "@section giveup",
          "@section field-rules",
          "@section parsing",
          "@section domain-rule-priority",
          "changeLevel/changeLevelReason"
        ],
        "optional": ["@section tunable"]
      },
      "skipped": ["@section topic-boundary"],
      "characteristics": {
        "changeLevelPurpose": "修改日志记录（非 topicEvolution）",
        "topicEvolutionEnabled": false,
        "needSemanticExtensionCheck": false
      }
    },
    {
      "templateId": "benchmark-topic-based",
      "taskType": "topic_based",
      "path": "templates/topic_based/template.md",
      "tags": {
        "required": [
          "@section constitution",
          "@section role",
          "@section topic-boundary",
          "@section convergence",
          "@section ask-rules",
          "@section output-schema",
          "@section completion",
          "@section validation",
          "@section modification",
          "@section off-task-detection",
          "@section giveup"
        ],
        "optional": ["@section tunable"]
      },
      "characteristics": {
        "changeLevelPurpose": "topicEvolution 分层留存",
        "topicEvolutionEnabled": true,
        "needSemanticExtensionCheck": "按场景判断",
        "hasTopicIdDeclaration": true,
        "hasChangeLevelRules": true,
        "hasN2DualRole": true,
        "nodeDescriptions": [
          "templates/topic_based/节点说明/N2_节点说明.md",
          "templates/topic_based/节点说明/N3_节点说明.md",
          "templates/topic_based/节点说明/N4_节点说明.md",
          "templates/topic_based/节点说明/N5_节点说明.md",
          "templates/topic_based/节点说明/N6_节点说明.md",
          "templates/topic_based/节点说明/N7_节点说明.md",
          "templates/topic_based/节点说明/N8_节点说明.md"
        ]
      }
    }
  ],
  "selectionRule": "N9 消费 N3 状态枚举。对每个 IN_SESSION 子类型，读取其 taskType → 匹配 templateId → 加载对应模板 → 按模板标签顺序引导。ANALYZING 节点固定使用 field_based 模板。"
}
