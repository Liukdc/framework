  "routeTable": {
    "ANALYZING": {
      "model": "fast-router",
      "outputLimit": "intent仅16个枚举值"
    },
    "IN_SESSION": {
      "defaultModel": "通用推理",
      "specialModels": {
        "n13": "代码生成专用"
      }
    }
  },
  "degradationChainRouting": [
    {
      "step": "L1结构校验",
      "description": "JSON.parse+Schema校验，失败→重试1次→熔断→硬编码回复"
    },
    {
      "step": "DET值域复验",
      "description": "field_based值域校验，规则来源N9 @section validation"
    },
    {
      "step": "confidence检查",
      "description": "冷启动软拦截/非冷启动硬拦截"
    },
    {
      "step": "跨任务延伸检测",
      "description": "DET字段白名单，needSemanticExtensionCheck=false"
    },
    {
      "step": "硬编码兜底",
      "description": "熔断后硬编码回复落盘"
    }
  ],
