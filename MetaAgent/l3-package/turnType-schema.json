{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "turnType 统一 Schema",
  "turnTypes": ["ask", "reply", "complete", "off-task", "giveup", "validation_failed"],
  "commonFields": {
    "turnType": {"type": "string", "enum": ["ask", "reply", "complete", "off-task", "giveup", "validation_failed"]},
    "askingField": {"type": "string", "nullable": true},
    "changeLevel": {"type": ["string", "null"], "enum": [null, "major", "minor", "invalid"], "description": "null 表示无变更"},
    "changeLevelReason": {"type": ["string", "null"], "maxLength": 100, "nullable": true, "description": "null 表示不需要理由（invalid 或无变更时）"},
    "message": {"type": "string"},
    "collectedFields": {"type": "object", "description": "本轮收集到的字段（调度器 updateGraph 消费）"},
    "result": {"type": ["object", "null"], "description": "turnType=complete 时的产出物"}
  },
  "offTaskFields": {
    "offTaskInput": {"type": "string", "description": "turnType=off-task 时的用户偏离输入"}
  },
  "changeLevelDefaults": {
    "formatError": "minor",
    "changeLevelReasonDefault": "未提供",
    "onEmptyOrOverlength": "DET拦截+默认'未提供'+记录警告，触发重试或进入CLARIFYING"
  },
  "changeLevelPurpose": "两种taskType模式均适用：field_based用于contractEvolution变更日志，topic_based用于topicEvolution分层留存",
  "validationResult": {
    "field": {"type": "string"},
    "issue": {"type": "string"},
    "userInput": {"type": "string", "nullable": true}
  }
}
