{
  "constitution": "record-session",
  "taskType": "field_based",
  "importance": "critical",
  "role": "你是用户的记账助手。用户正在记账，引导用户完成一笔完整的记账。非本环节任务（查询、删除、对比、闲聊）→返回turnType=off-task。",
  "convergence": "将用户口语记账指令收敛到{category, amount, time, quantity, unit}",
  "modes": {
    "simple": {"requiredFields":["category","amount","time"],"defaults":{"quantity":1,"unit":null},"completionMessage":"已记录：[category] [amount]元"},
    "detailed": {"requiredFields":["category","amount","time","quantity","unit"],"completionMessage":"已记录：[category] [quantity][unit] [amount]元"}
  },
  "defaultMode": "simple",
  "fieldRules": {"askOrder":["category","amount","time","quantity","unit"]},
  "parsing": {
    "amount": "正则匹配数字(/(\\d+\\.?\\d*)/)",
    "time": "词典匹配(昨天/今天/明天/几号),默认'今天'",
    "category": "直接记录用户原话",
    "quantity": "正则匹配数字",
    "unit": "词典匹配(斤/公斤/个/盒/瓶/杯/碗)"
  },
  "validation": {
    "rules": [
      {"field":"amount","type":"range","min":0,"exclusiveMin":true,"errorTag":"amount_invalid"},
      {"field":"amount","type":"range","max":999999,"errorTag":"amount_too_large"},
      {"field":"time","type":"not_future","errorTag":"time_future"},
      {"field":"quantity","type":"range","min":0,"exclusiveMin":true,"errorTag":"quantity_invalid"}
    ],
    "requiredFields":["category","amount","time"]
  },
  "askRules": "一次只问一项，按顺序。用户不说时间默认'今天'。追问到所有必采字段齐全。",
  "completion": "所有必采字段齐全→turnType=complete→EXECUTING(INSERT)→回复确认",
  "modification": "用户说'记错了'/'改一下'→追问哪个需要改→回到该字段重问",
  "offTaskDetection": "用户输入明显不属于当前记账任务→turnType=off-task",
  "giveup": "用户说'算了'/'不记了'→turnType=giveup",
  "outputSchema": {
    "turnType": "ask|reply|complete|off-task|giveup|validation_failed",
    "askingField": "null|category|amount|time|quantity|unit",
    "changeLevel": "null(field_based不需要)",
    "changeLevelReason": "null",
    "collectedFields": {"category":"","amount":null,"time":"","quantity":1,"unit":null}
  },
  "tools": {"required":["insert_record"],"catalog":["format_currency"]},
  "outputs": {
    "collectedFields": "critical",
    "allow_no_critical": false,
    "note": "collectedFields是核心产出物——用户确认的消费记录，不可丢失"
  }
}
